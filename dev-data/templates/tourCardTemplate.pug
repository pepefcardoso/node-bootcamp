.card
  .card__header
    .card__picture
      .card__picture-overlay &nbsp;
      img.card__picture-img(src='img/tour-1-cover.jpg', alt='Tour 1')
    h3.heading-tertirary
      span The Chapada Hiker

  .card__details
    h4.card__sub-heading Medium 6-day tour
    p.card__text Breathtaking hike through the lush trails of Chapada Diamantina
    .card__data
      svg.card__icon
        use(xlink:href='img/icons.svg#icon-map-pin')
      span Lençóis, Brazil
    .card__data
      svg.card__icon
        use(xlink:href='img/icons.svg#icon-calendar')
      span April 2026
    .card__data
      svg.card__icon
        use(xlink:href='img/icons.svg#icon-flag')
      span 3 stops
    .card__data
      svg.card__icon
        use(xlink:href='img/icons.svg#icon-user')
      span 20 people

  .card__footer
    p
      span.card__footer-value $415
      span.card__footer-text per person
    p.card__ratings
      span.card__footer-value 4.8
      span.card__footer-text rating (42)
    a.btn.btn--green.btn--small(href='#') Details